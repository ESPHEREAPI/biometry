		$modalFormMedicament.on("submit", function() {

			if($nomMedicament.val().length < 2)
			{
				$ligneNomMedicament.addClass("has-error");

				messageErreur = '<ul class="form-error"><li>';
				messageErreur += "<?= $this->translate("Veuillez saisir le nom du médicament (au moins 2 caractères)", "application"); ?>";
				messageErreur += '</li></ul>';

				$nomMedicament.after(messageErreur);
				return false;
			}

			dataString = "nomMedicament="+$nomMedicament.val();

			 // Launch AJAX request.
			 $.ajax({

				type: "post",

				url: "<?= $this->basePath(); ?>/<?= $appliConfig->get('lienBackoffice'); ?>/<?= $this->naturePrestation; ?>/ajouter-medicament-ajax",
					
				data: dataString,
					
				beforeSend: function() {
					$modalFormMedicament.find("#error-form").remove();
					retirerAlert("modal-medicament-body");

					mettreLoaderSurDiv("modal-medicament-body" , "<?= $this->translate("En cours de traitement, veuillez patienter ...", "application"); ?>", "");
				},
					
				success: function( html ) {
					if(html.error != "")
					{
						mettreErreurSurDiv("modal-medicament-body" , html.error, "");
					}
					else if(html.medicamentArray != "")
					{
						$nomMedicament.val("");
						idSelectActuelHere = idSelectActuel;

						$('body').find("select.selectMedicament").each(function (index, value) {
							$elt = $(this);
							if($elt.attr("id") != undefined)
							{
								var data = {
									id: html.medicamentArray.id,
									text: html.medicamentArray.nom
								};
                                 
								 loader="#loader_"+idLigne;
                       // Hide image container
					   if("<?= $this->naturePrestation; ?>"=="examen")
						 {
                       $(loader).hide();
					     }
								console.log($elt.attr("id"));

								if($elt.attr("id") == idSelectActuelHere)
								{
									var newOption = new Option(data.text, data.id, true, true);
								}
								else
								{
									var newOption = new Option(data.text, data.id, false, false);
								}
								
								$elt.append(newOption).trigger('change');						
							}
						});

						$modalMedicament.modal('toggle');
					}
				},

				error: function() {
					mettreErreurSurDiv("modal-medicament-body" , "Probleme d'acces au server, veuillez reessayer plus tard", "");
				},

				complete: function() {
					retirerLoaderSurDiv("modal-medicament-body");
					
				}
			});
			return false;
		});
		
		if($originformAjoutPrestation.val() == "ajout")
		{
			if("<?= $sessionEmploye->offsetGet("type_sous_profil"); ?>" == "centre_hospitalier")
			{
				$prestataire.val("<?= $sessionEmploye->offsetGet("id_prestataire"); ?>");
			}
			else if (("<?= $sessionEmploye->offsetGet("type_sous_profil"); ?>" == "pharmacie") || ("<?= $sessionEmploye->offsetGet("type_sous_profil"); ?>" == "laboratoire"))
			{
				if ("<?= $codeVisite; ?>" != "")
				{
				 $prestataire.val("<?= $prestat; ?>");
				}
			}
			
			ajouterLigneTemplate("");
		}
		else if($originformAjoutPrestation.val() == "modif")
		{
			$("#ligne_visite, #ligne_prestataire").hide();
			$("#ctneurTsLignePrestation").show(500);
			$("#submit").slideDown(500);



			$.each(tabLignePrestationModif, function( key, value ) {
				ajouterLigneTemplate(value);
        	});
		}	
		
