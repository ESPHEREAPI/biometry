	function retirerLigneTemplate($this, retirerPremier)
    {
		var $row  = $this.parents('.form-group'),
        index = $row.attr('data-book-index');

		if(retirerPremier == "1" || $formPrestation.find(".lignePrestation").length > 1)
		{
			// Remove fields
	        $formPrestation
	        	.formValidation('removeField', $row.find('[name="nomTemplate_'+index+'"]'));
	            // .formValidation('removeField', $row.find('[name="nbreTemplate_'+index+'"]'));
	            // .formValidation('removeField', $row.find('[name="posologieTemplate_'+index+'"]'));


	        if("<?= $this->naturePrestation ?>" == "ordonnance")
	        {
	        	$formPrestation
				.formValidation('removeField', $row.find('[name="montantTemplate_'+index+'"]'))
	            .formValidation('removeField', $row.find('[name="nbreTemplate_'+index+'"]'))
	            .formValidation('removeField', $row.find('[name="posologieTemplate_'+index+'"]'));
	        }
	        else if("<?= $this->naturePrestation ?>" == "examen" || "<?= $this->naturePrestation ?>" == "lunetterie")
	        {
	        	$formPrestation
				.formValidation('removeField', $row.find('[name="montantTemplate_'+index+'"]'))
	            .formValidation('removeField', $row.find('[name="nbreTemplate_'+index+'"]'))
	            .formValidation('removeField', $row.find('[name="typeExamenTemplate_'+index+'"]'));
	        }
            
	
	        // Remove element containing the fields
	        $row.remove();

	        delete tabLignePrestation[index];
		}
    }
    
</script>