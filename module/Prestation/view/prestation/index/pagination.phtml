	    $varRetour .= '<li><a href="'.$basePath.'/'.$appliConfig->get('lienBackoffice').'/'.$this->naturePrestation.'/modifier/'.$element->getId().'"><i class="fa fa-edit"></i> '.$this->getTranslator("Modifier").'</a></li>';
	}
	
	
	if($afficherImprimerPrestationButton)
	{
	    $varRetour .= '<li><a href="##" class="imprimerRecuPrestation" id="imprimerRecuPrestation_'.$element->getId().'" rel="'.$element->getId().'"><i class="fa fa-print"></i> '.$this->getTranslator("Imprimer").'</a></li>';
	}
	
    
    if($afficherSupprimerPrestationButton)
    {
        $varRetour .= '<li><a href="'.$basePath.'/'.$appliConfig->get('lienBackoffice').'/supprimer_commun/1/Prestation/'.$element->getId().'"><i class="fa fa-trash-o"></i> '.$this->getTranslator("Supprimer").'</a></li>';
