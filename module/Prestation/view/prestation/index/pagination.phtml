							                        <span class="sr-only">'.$this->getTranslator("Toggle Dropdown").'</span>
							                      </button>
							                      <ul role="menu" class="dropdown-menu rsv-btn-group-tab">';
    
	
	$varRetour .= '<li><a href="'.$basePath.'/'.$appliConfig->get('lienBackoffice').'/'.$this->naturePrestation.'/details/'.$element->getId().'"><i class="fa fa-list"></i> '.$this->getTranslator("Details").'</a></li>';
	
