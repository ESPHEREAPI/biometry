    {
        $classLigne = "attente_validation";
    }
	 if($nbreLignePrestationValide >= 1)
    {
        $classLigne = "valide";
    }
    
    
    
    $varRetour .= '    <tr id="ligne_prestation_'.$element->getId().'"
