    {
        $consultation->afficheChaine();
        $natureAffection = $consultation->getNatureAffection();
    }
    
    
    
    $afficherModifierPrestationButton = $this->prestationManager->vefifierSiPrestationModifiable($element) && $peuxModifierPrestation;
    $afficherImprimerPrestationButton = $this->prestationManager->vefifierSiPrestationImprimable($element, $sessionEmploye->offsetGet("id_prestataire")) && $peuxImprimerPrestation;
    
    $afficherSupprimerPrestationButton = $this->prestationManager->vefifierSiPrestationSupprimable($element);
    
    
    $nbreLignePrestationAttenteValidation = $this->prestationManager->getNbreLignePrestationAttenteValidation($element);
    $classLigne = "";
    
	$nbreLignePrestationAttenteValidation = $this->prestationManager->getNbreLignePrestationAttenteValidation($element);
	 $nbreLignePrestationValide = $this->prestationManager->getNbreLignePrestationValide($element);
    $classLigne = "";
