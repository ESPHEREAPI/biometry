        <script type="text/javascript">		         
			$(document).ready(function() {
				
				basePathBackoffice = "<?= $this->basePath()."/".$appliConfig->get('lienBackoffice'); ?>";
				
				$("body").on("click", "#activer_commun, #desactiver_commun, #supprimer_commun", function() {
					$this = $(this);
					statut = "";
					if($this.attr("id") == "activer_commun")
					{
						statut = 1;
					}
					else if($this.attr("id") == "desactiver_commun")
					{
						statut = -1;
					}
					
					idElt = "";
					$("#liteEltsTab input[name='elt_check_tableau']").each(function( index ) {
						$thisHere = $(this);
						if($thisHere.prop('checked') == true)
						{
							if(idElt != "")
								idElt += ";";
							
							idElt += $thisHere.attr("rel");
						}
						  
					});
		
					if(idElt == "")
					{
						jAlert("<?= $this->translate("Vous devez selectionner au moins un element pour effectuer cette action", "application"); ?>", "<?= $this->translate("Avertissement", "application"); ?>");
					}
					else
					{
						if($this.attr("id") == "activer_commun" || $this.attr("id") == "desactiver_commun")
						{
							window.location = '<?= $this->basePath(); ?>/<?= $appliConfig->get('lienBackoffice'); ?>/activer_commun/'+statut+'/<?= $this->nomEntite; ?>/'+idElt;
						}
						else if($this.attr("id") == "supprimer_commun")
						{
							window.location = '<?= $this->basePath(); ?>/<?= $appliConfig->get('lienBackoffice'); ?>/supprimer_commun/1/'+'<?= $this->nomEntite; ?>/'+idElt;
						}
					}
		        });
		
