		        $("#formFiltreListeElt input.number").inputmask('decimal',
		        	{ 
			        	'alias': 'numeric',
			            'groupSeparator': '  ',
			            'autoGroup': true,
			            'digits': 2,
			            'radixPoint': ",",
			            'digitsOptional': false,
			            'allowMinus': false,
			            'rightAlign': false
		          }
		        );
		
		        $( "input[type='text'].date" ).datepicker({
		            changeYear: true,
		            changeMonth: true,
		            numberOfMonths: 1,
		            dateFormat: "yy-mm-dd"
		        });
		
		        $("#formFiltreListeElt").on("change", "select", function() {
					choisirPage(1);
		        });
		
		        $("body").on("click", "table.tableSortinMsbt tr th.isOrdered", function() {
		
					$this = $(this);
		
					nomColoneTriPagination = $this.attr("nomColone");
					
					if($this.hasClass("sorting_asc")) 
					{
						typeTriColonePagination = "DESC";
						otherElementsToPost = "&nomColoneTriPagination="+nomColoneTriPagination+"&typeTriColonePagination="+typeTriColonePagination+"&nbreMaxLigneTableau="+nbreMaxLigneTableau;
					}
					else
					{
						typeTriColonePagination = "ASC";
						otherElementsToPost = "&nomColoneTriPagination="+nomColoneTriPagination+"&typeTriColonePagination="+typeTriColonePagination+"&nbreMaxLigneTableau="+nbreMaxLigneTableau;
					}
					
		        	choisirPage(1);
		        });
		
		        $("body").on("change", "#selectNbreLignePagin", function() {
		
					$this = $(this);
					nbreMaxLigneTableau = $this.val();
					otherElementsToPost = "&nomColoneTriPagination="+nomColoneTriPagination+"&typeTriColonePagination="+typeTriColonePagination+"&nbreMaxLigneTableau="+nbreMaxLigneTableau;
					
		        	choisirPage(1);
		        });
		
