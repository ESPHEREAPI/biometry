	$varRetour .= '        <td>'.$element->getCategorie()->getNom().'</td>';
	$varRetour .= '        <td>'.$nomVilleLangue.'</td>';
	
	$varRetour .= '        <td>'.$element->getTelephone().'</td>';
	$varRetour .= '        <td>'.$element->getEmail().'</td>';
	$varRetour .= '        <td>'.$element->getAdresse().'</td>';
	
	
	
	$varRetour .= '        <td class="rsv-table-elt-btn"><a href="'.$basePath.'/'.$appliConfig->get('lienBackoffice').'/activer_commun/'.$newStatut.'/Prestataire/'.$element->getId().'"><span class="'.$classtatut.'" title="'.$titleStatut.'"></span></a></td>';
	$varRetour .= '        <td class="rsv-table-elt-btn">';
	$varRetour .= '             <div class="btn-group">
							                      <button class="btn btn-default btn-modifier-heres" type="button" href="'.$basePath.'/'.$appliConfig->get('lienBackoffice').'/administration/prestataire/modifier/'.$element->getId().'"><a><i class="fa fa-edit"></i> '.$this->getTranslator("Modifier").'</a></button>
