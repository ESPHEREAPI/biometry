foreach($tab as $element)
{
	if($element->getStatut() == -1) { $classtatut =  "table_inactive"; $titleStatut =  $this->getTranslator("Activer"); $newStatut = 1; }
	else { $classtatut =  "table_active"; $titleStatut =  $this->getTranslator("Desactiver"); $newStatut = -1; }
	
	$element->afficheChaine();
	
	$ville = $element->getVille();
	
	$nomVilleLangue = "";
	if($ville)
	{
	    $villeLangue = $this->getEntityManager()->getRepository('Entity\VilleLangue')->findOneBy(array('ville' => $ville->getId(), 'langue' => $sessionEmploye->offsetGet("id_langue")));
	    if($villeLangue)
	    {
	        $villeLangue->afficheChaine();
	        $nomVilleLangue = $villeLangue->getNom();
	    }
	}
	
		
	$varRetour .= '    <tr>';
	$varRetour .= '        <td class="rsv-table-elt-btn"><input type="checkbox" name="elt_check_tableau" class="elt_check_tableau" rel="'.$element->getId().'" /></td>';
