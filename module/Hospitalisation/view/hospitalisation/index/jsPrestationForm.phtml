	function ajouterLigneTemplate(uneLignePrestation)
    {
		// console.log(uneLignePrestation);
	    
	    if(uneLignePrestation == "")
	    {
	    	lignePrestationIndex = uniqid();
	    }
	    else
	    {
	    	lignePrestationIndex = uneLignePrestation.id;
	    }
	    
		var $template = $('#lignePrestation'),
        $clone    = $template
                        .clone()
                        .removeClass('hide')
                        .addClass('lignePrestation')
                        .removeAttr('id')
                        .attr('id', 'lignePrestation_'+lignePrestationIndex)
                        .attr('data-book-index', lignePrestationIndex)
                        .insertBefore($template);

		
		
		if(uneLignePrestation != "")
        {
			$clone.attr("idLignePrestation", uneLignePrestation.id);
        	$clone.attr("idPrestation", uneLignePrestation.idPrestation);
        	$clone.attr("id", "lignePrestation_"+uneLignePrestation.id);

        	$clone
            .find('button.removeButton').removeClass("btn-supprimer-simple").addClass("btn-supprimer-commun-ajax");



        	$clone
            .find('button.removeButton').attr("nomCamelCaseTable", "LignePrestation");

        	$clone
            .find('button.removeButton').attr("nomCamelCaseColonnePosition", "");
		
        	$clone
            .find('button.removeButton').attr("otherCulumnsUniqWithPosition", "");
			
			$clone
            .find('button.removeButton').attr("newStatutSupprime", "1");


			
        	$clone
            .find('button.removeButton').attr("idElts", uneLignePrestation.id);

        	$clone
            .find('button.removeButton').attr("retirerPremier", "-1");
        	

        	$clone
            .find('button.removeButton').attr("callbackSuccesSupprimerCommun", "1");

        	$clone
            .find('button.removeButton').attr("idHtmlLigne", 'lignePrestation_'+lignePrestationIndex);
            

			if(!uneLignePrestation.modifiable)
			{
				$clone
        		.find('[name="plafondTemplate"]').prop('disabled', true).end()
	            // .find('[name="nbreTemplate"]').prop('disabled', true).end()
	            // .find('[name="posologieTemplate"]').prop('disabled', true).end()
	            .find('button.removeButton').prop('disabled', true).end();

	            
	            	$clone
		            .find('[name="typeExamenTemplate"]').prop('disabled', true).end();
				
				$clone
        		.find('[name="observationsTemplate"]').prop('disabled', true).end()
					
	           
			}

        	

            
            	$clone
	            .find('[name="typeExamenTemplate"]').attr('idLignePrestation', uneLignePrestation.id).val(uneLignePrestation.typeExamen).end();
			
			   $clone
        		.find('[name="plafondTemplate"]').attr('idLignePrestation', uneLignePrestation.id).val(uneLignePrestation.plafond).end();
			
			 $clone
        		.find('[name="observationsTemplate"]').attr('idLignePrestation', uneLignePrestation.id).val(uneLignePrestation.observations).end();
	            // .find('[name="nbreTemplate"]').attr('idLignePrestation', uneLignePrestation.id).val(uneLignePrestation.nbre).end();
	            // .find('[name="posologieTemplate"]').attr('idLignePrestation', uneLignePrestation.id).val(uneLignePrestation.posologie).end();
          
            
        }
		else
		{
			$clone
            .find('button.removeButton').removeClass("btn-supprimer-commun-ajax").addClass("btn-supprimer-simple");
		}


		

		// return false;

        // Update the name attributes
        $clone
        	.find('[name="plafondTemplate"]').attr('name', 'plafondTemplate_'+lignePrestationIndex).end()
            // .find('[name="nbreTemplate"]').attr('name', 'nbreTemplate_'+lignePrestationIndex).end()
            // .find('[name="posologieTemplate"]').attr('name', 'posologieTemplate_'+lignePrestationIndex).end()
            .find('[name="idLignePrestationBD"]').attr('name', 'idLignePrestationBD_'+lignePrestationIndex).val(uneLignePrestation.id).end();


        $clone
        	.find('[name="observationsTemplate"]').attr('name', 'observationsTemplate_'+lignePrestationIndex).end()
        	
            
        	 $clone
         	.find('[name="typeExamenTemplate"]').attr('name', 'typeExamenTemplate_'+lignePrestationIndex).end();
		
		
       
        

        // Add new fields
        // Note that we also pass the validator rules for new field as the third parameter
        //$formPrestation
        	//.formValidation('addField', 'plafondTemplate_'+lignePrestationIndex, plafondTemplateValidators);
            // .formValidation('addField', 'nbreTemplate_'+lignePrestationIndex, nbreTemplateValidators);
            // .formValidation('addField', 'posologieTemplate_'+lignePrestationIndex, posologieTemplateValidators)   
            
       	
        	$formPrestation
            .formValidation('addField', 'typeExamenTemplate_'+lignePrestationIndex, typeExamenTemplateValidators);
       
        
		 

		// alert(tabLignePrestation);
        // return false;
		
        tabLignePrestation[lignePrestationIndex] = lignePrestationIndex;
    }

	function retirerLigneTemplate($this, retirerPremier)
    {
		var $row  = $this.parents('.form-group'),
        index = $row.attr('data-book-index');

		if(retirerPremier == "1" || $formPrestation.find(".lignePrestation").length > 1)
		{
			// Remove fields
	        $formPrestation
	        	.formValidation('removeField', $row.find('[name="plafondTemplate_'+index+'"]'));
	            // .formValidation('removeField', $row.find('[name="nbreTemplate_'+index+'"]'));
	            // .formValidation('removeField', $row.find('[name="posologieTemplate_'+index+'"]'));


	        
	        	$formPrestation
	            .formValidation('removeField', $row.find('[name="typeExamenTemplate_'+index+'"]'));
			
			
            
	
	        // Remove element containing the fields
	        $row.remove();

	        delete tabLignePrestation[index];
		}
    }
    
