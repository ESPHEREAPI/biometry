	function callbackSuccesFormValidation(html, tabAutresParametres, varRetour)
    {
		$.confirm({
    		icon: 'fa fa-check',
    	    title: "<?=  $this->translate("Succes", "application");?>",
    	    content: "<?=  $this->translate("Operation effectuee avec success", "application");?>",
    	    type: 'green',
    	    typeAnimated: true,
    	    buttons: {
    	        close: {
    	            text: "<?=  $this->translate("OK", "application");?>",
    	            action: function(){

						if($originformAjoutPrestation.val() == "ajout" || ($originformAjoutPrestation.val() == "modif" && btnSubmit == "submitClose"))
						{
							window.location = "<?= $this->basePath(); ?>/<?= $appliConfig->get('lienBackoffice'); ?>/<?= $this->naturePrestation; ?>";
						}
						else if($originformAjoutPrestation.val() == "modif" && btnSubmit == "submit")
						{
							location.reload();
						}
	                }
    	        },
    	    }
    	});
    }


